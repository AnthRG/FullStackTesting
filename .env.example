# Variables para docker-compose (todas opcionales, defaults de localhost)
# Copia este archivo a .env y edita lo que necesites: cp .env.example .env

# --- Puertos publicados en el host ---
FRONTEND_PORT=5173
BACKEND_PORT=8080
POSTGRES_PORT=5432

# --- Base de datos ---
POSTGRES_DB=fullstacktesting
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# --- Backend ---
# URL JDBC que usa el backend. En compose el host es "db"; corriendo local usa localhost.
SPRING_DATASOURCE_URL=jdbc:postgresql://db:5432/fullstacktesting
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Frontend (build time) ---
# URL del backend que queda compilada en el bundle de Vite
VITE_API_URL=http://localhost:8080
